<Window
    x:Class="WallpaperSwitcher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WallpaperSwitcher"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid x:ConnectionId='2' x:Name="RootGrid" Padding="16" Background="Transparent" CornerRadius="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header and Custom Toast Notification Area -->
        <Grid Grid.Row="0" Margin="8,0,0,16">
            <TextBlock Text="Wallpapers" 
                       FontSize="18" 
                       FontWeight="SemiBold" 
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" 
                       VerticalAlignment="Center"/>
                       
            <Border x:ConnectionId='10' x:Name="ToastNotification" 
                    Background="{ThemeResource SystemAccentColor}" 
                    CornerRadius="6" 
                    Padding="12,6" 
                    HorizontalAlignment="Right" 
                    Opacity="0"
                    IsHitTestVisible="False">
                <TextBlock x:ConnectionId='11' x:Name="ToastText" Foreground="White" FontSize="12" FontWeight="Medium" />
            </Border>
        </Grid>

        <!-- Grid layout for images -->
        <GridView x:ConnectionId='3' Grid.Row="1"
                  x:Name="WallpaperGridView"
                                            
                  IsItemClickEnabled="True"
                  SelectionMode="None"
                  HorizontalAlignment="Center"
                  ScrollViewer.VerticalScrollBarVisibility="Hidden">
            
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid MaximumRowsOrColumns="2" Orientation="Horizontal" HorizontalAlignment="Center" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <GridView.ItemTemplate>
                <DataTemplate                              >
                    <Grid x:ConnectionId='5' Width="130" Height="90" Margin="6" CornerRadius="12" Background="#1AFFFFFF">
                        <Grid.Transitions>
                            <TransitionCollection>
                                <RepositionThemeTransition />
                            </TransitionCollection>
                        </Grid.Transitions>
                        
                        <Image x:ConnectionId='6'                            Stretch="UniformToFill" />
                        
                        <!-- Hover Effect Border -->
                        <Border BorderBrush="{ThemeResource SystemAccentColor}" 
                                BorderThickness="2" 
                                CornerRadius="12" 
                                Opacity="0"
                                x:Name="HoverBorder">
                            <!-- In WinUI 3, we can use RevealBrush or pointer states in code-behind for simplicity since x:Bind to VisualStateManager needs full templating -->
                        </Border>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
            
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="CornerRadius" Value="12" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="GridViewItem">
                                <ListViewItemPresenter 
                                    ContentTransitions="{TemplateBinding ContentTransitions}"
                                    CornerRadius="12"
                                    PointerOverBackground="#1AFFFFFF" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </GridView.ItemContainerStyle>
        </GridView>
    </Grid>
</Window>

